# Copie para .env e preencha com os seus valores (não commite o .env).

# String de conexão do MongoDB Atlas ou local, ex.:
# mongodb+srv://USUARIO:SENHA@cluster.xxxxx.mongodb.net/nome_do_banco?retryWrites=true&w=majority
MONGODB_URI= 

# Chave secreta para assinar tokens JWT (use uma string longa e aleatória)
JWT_SECRET=troque-por-pelo-menos-16-caracteres-aleatorios

# Porta da API (opcional; padrão 3001)
PORT=3001
